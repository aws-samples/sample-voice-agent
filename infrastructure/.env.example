# ===================================
# Environment Configuration
# ===================================
# Valid values: poc, dev, staging, prod
ENVIRONMENT=poc

# ===================================
# AWS Configuration
# ===================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ===================================
# Project Configuration
# ===================================
PROJECT_NAME=voice-agent
VPC_CIDR=10.0.0.0/16
MAX_AZS=3
NAT_GATEWAYS=2

# ===================================
# Deepgram SageMaker Configuration
# ===================================
# Model package ARNs from AWS Marketplace subscription
# Subscribe to Deepgram at: https://aws.amazon.com/marketplace/seller-profile?id=deepgram
# After subscription, find the ARNs in the SageMaker console or Marketplace
DEEPGRAM_STT_MODEL_PACKAGE_ARN=arn:aws:sagemaker:us-east-1:aws:model-package/deepgram-nova-3-general-PLACEHOLDER
DEEPGRAM_TTS_MODEL_PACKAGE_ARN=arn:aws:sagemaker:us-east-1:aws:model-package/deepgram-aura-PLACEHOLDER

# ===================================
# External Service Configuration
# ===================================
# These values are populated in Secrets Manager after deployment
# DAILY_API_KEY=<obtained from Daily.co dashboard>
# DEEPGRAM_API_KEY=<obtained from Deepgram dashboard - if using cloud fallback>

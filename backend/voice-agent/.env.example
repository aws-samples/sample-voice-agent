# Voice Pipeline Configuration
# Copy this file to .env and fill in your values

# Provider Selection (deepgram/sagemaker for STT, cartesia/sagemaker for TTS)
STT_PROVIDER=deepgram
TTS_PROVIDER=cartesia

# Cloud API Keys (required when using cloud providers)
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# SageMaker Endpoints (required when using sagemaker provider)
# STT_ENDPOINT_NAME=your-stt-endpoint
# TTS_ENDPOINT_NAME=your-tts-endpoint

# AWS Configuration (required for Bedrock LLM)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Daily.co Configuration (for WebRTC and PSTN)
DAILY_API_KEY=your-daily-api-key
# These are set automatically by setup-daily.sh:
# DAILY_PHONE_NUMBER=+14155551234
# DAILY_HMAC_SECRET=base64-encoded-secret

# Logging
LOG_LEVEL=INFO
